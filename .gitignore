# ===== Secrets (never commit) =====
.env
*.local.env
!.env.example

# ===== Bulky / generated CONTENT =====
# Keep the folder skeleton (via .gitkeep) but ignore everything inside.
/AUDIO/**
/Transcripts/**
/Transcripts_auto/**
!/AUDIO/**/
!/Transcripts/**/
!/Transcripts_auto/**/
!.gitkeep

# Content file types anywhere (safety net; also ignores loose deliverable docs)
*.mp3
*.wav
*.m4a
*.aac
*.flac
*.ogg
*.docx
*.srt

# ===== Claude Code (personal/local only) =====
.claude/settings.local.json
.claude/*.local.json
.claude/history/
.claude/todos/
.claude/shell-snapshots/

# ===== Python =====
__pycache__/
*.pyc
venv/
.venv/
*.egg-info/

# ===== OS / Office temp =====
~$*
.DS_Store
Thumbs.db
desktop.ini

# ===== JetBrains / PyCharm =====
.idea/
